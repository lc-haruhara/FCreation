{
  "name": "absolute-five-astro-for-microcms",
  "type": "module",
  "version": "0.0.1",
  "packageManager": "pnpm@10.32.1",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "astro build && node scripts/relativize-paths.mjs",
    "preview": "astro preview",
    "check": "astro check",
    "astro": "astro",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "postinstall": "patch-package",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "lint:scss": "stylelint \"src/**/*.{scss,css}\"",
    "format:scss": "pnpm exec prettier --write \"**/*.scss\"",
    "check:scss": "pnpm exec prettier --check \"**/*.scss\"",
    "audit:deps": "pnpm audit --audit-level=moderate",
    "audit:deps:prod": "pnpm audit --prod --audit-level=moderate",
    "deps:outdated": "pnpm outdated"
  },
  "dependencies": {
    "astro": "^6.1.1",
    "gsap": "^3.14.2",
    "sharp": "^0.34.5",
    "swiper": "^12.1.3",
    "twemoji": "^14.0.2"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.8",
    "@eslint/js": "^9.39.4",
    "@storybook-astro/framework": "^1.1.0",
    "@storybook/builder-vite": "^10.3.3",
    "@types/node": "^25.5.0",
    "cross-env": "^10.1.0",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-astro": "^1.6.0",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "eslint-plugin-unused-imports": "^4.4.1",
    "globals": "^16.5.0",
    "patch-package": "^8.0.1",
    "postcss": "^8.5.8",
    "postcss-html": "^1.8.1",
    "postcss-scss": "^4.0.9",
    "prettier": "3.8.1",
    "prettier-plugin-astro": "0.14.1",
    "sass-embedded": "^1.98.0",
    "storybook": "^10.3.3",
    "stylelint": "^17.6.0",
    "stylelint-config-recess-order": "^7.7.0",
    "stylelint-config-standard-scss": "^17.0.0",
    "stylelint-order": "^8.1.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.2"
  }
}