---
import { Image, LabelCatch } from '@/components/elements/index';
import ElementsItemImage from '../../ElementsItemImage.astro';
import { BlockCTA } from '@/components/layouts/index';
import './HeroB.scss';
---

<section class="p-top-hero">
  <div class="p-top-hero-body">
    {/* :::::::::::::::::::::::::::::::::::::::::::::::::: */}
    {/* Detail                                             */}
    {/* :::::::::::::::::::::::::::::::::::::::::::::::::: */}
    <div class="p-top-hero-detail">
      <span class="p-top-hero-detail-copy">
        <span class="p-top-hero-detail-copy-body">
          <span class="p-top-hero-detail-copy-text">
            <span class="p-top-hero-detail-copy-row">
              <LabelCatch text="Keep It" />
              <LabelCatch text="Original." color="yellow" />
            </span>
            <span class="p-top-hero-detail-copy-row">
              <LabelCatch text="Order" color="pink" />
              <LabelCatch text=" It Custom." />
            </span>
          </span>
          <span class="p-top-hero-detail-copy-logo">
            <Image imagePath="logo/logo-main.svg" altText="Hero Detail" />
          </span>
        </span>
      </span>
      <p class="p-top-hero-detail-description">スポーツもアパレルも、完全オーダーメイド</p>

      {/* Card :::::::::::::::::::::::::::::::::::: */}
      <div class="p-top-hero-detail-card">
        <div class="p-top-hero-detail-card-item">
          <div class="p-top-hero-detail-card-item-icon">
            <Image imagePath="icon/hero-points1.svg" altText="耐久性に優れた高品質" />
          </div>
          <p class="p-top-hero-detail-card-item-text">
            耐久性に<br />優れた高品質
          </p>
        </div>
        <div class="p-top-hero-detail-card-item">
          <div class="p-top-hero-detail-card-item-icon">
            <Image imagePath="icon/hero-points2.svg" altText="専任デザイナーに丸投げOK" />
          </div>
          <p class="p-top-hero-detail-card-item-text">
            専任デザイナーに<br />丸投げOK
          </p>
        </div>
        <div class="p-top-hero-detail-card-item">
          <div class="p-top-hero-detail-card-item-icon">
            <Image imagePath="icon/hero-points3.svg" altText="LINEに丸投げで完結" />
          </div>
          <p class="p-top-hero-detail-card-item-text">
            LINEに<br />丸投げで完結
          </p>
        </div>
      </div>

      {/* BlockCTA :::::::::::::::::::::::::::::::::::: */}
      <BlockCTA detailText="" />
    </div>

    {/* :::::::::::::::::::::::::::::::::::::::::::::::::: */}
    {/* Image                                             */}
    {/* :::::::::::::::::::::::::::::::::::::::::::::::::: */}
    <div class="p-top-hero-image">
      <div class="p-top-hero-image-item">
        <img src="/images/hero-model1.jpg" alt="" />
      </div>
      <div class="p-top-hero-image-item">
        <img src="/images/hero-model2.jpg" alt="" />
      </div>
    </div>
  </div>

  {/* :::::::::::::::::::::::::::::::::::::::::::::::::: */}
  {/* ItemImage                                         */}
  {/* :::::::::::::::::::::::::::::::::::::::::::::::::: */}
  <ElementsItemImage />
</section>
