---
import './TextLoop.scss';
import { LabelCatch } from '@/components/elements/index';

interface Props {
  texts: string[];
  color?: string;
  reverse?: boolean;
}

const { texts, color = '', reverse = false } = Astro.props;
---

<div class:list={['c-decoration-text-loop', reverse && '_reverse']} aria-hidden="true">
  <div class="c-decoration-text-loop-row">
    {[0, 1, 2].map(() => (
      <div class="c-decoration-text-loop-body">
        {texts.map((text) => (
          <LabelCatch {text} size="copy" color={color} />
        ))}
      </div>
    ))}
  </div>
</div>
