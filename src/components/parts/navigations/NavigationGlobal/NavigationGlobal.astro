---
import './NavigationGlobal.scss';

import { ButtonCTA, Image } from '@/components/elements/index';
import { NavigationDrawer } from '@/components/parts/index.ts';
import { getNavPages } from '@/core/lib/pages';

interface Props {
  showNav?: boolean;
}

const { showNav = true } = Astro.props;

const globalPages = getNavPages('global');
const currentPath = Astro.url.pathname;

// 英語だけのテキストか判定
function isEnglishOnlyText(s: string) {
  const v = s.trim();
  if (!v) return false;

  const hasLatinLetter = /[A-Za-z]/u.test(v);
  const englishLike = /^[A-Za-z0-9\s.,!?&/()'"’:;-]+$/u.test(v);

  return hasLatinLetter && englishLike;
}
---

<div class="c-global-navigation">
  <div class="c-global-navigation-body">
    {/* :::::::::::::::::::::::::::::::::::::::::::::::::: */}
    {/* Logo                                               */}
    {/* :::::::::::::::::::::::::::::::::::::::::::::::::: */}
    <a href="/" class="c-global-navigation-logo" data-js-scroll-top>
      <Image imagePath="logo/logo-main.svg" altText="Logo" />
    </a>

    <div class="c-global-navigation-group">
      {/* :::::::::::::::::::::::::::::::::::::::::::::::::: */}
      {/* Navigation Global                                  */}
      {/* :::::::::::::::::::::::::::::::::::::::::::::::::: */}
      <nav class="c-global-navigation-nav" aria-label="グローバルナビゲーション">
        <ul class="c-global-navigation-list">
          <li class="c-global-navigation-list-item">
            <a href="#home" class="c-global-navigation-list-item-body">
              <span lang="en">Home</span>
            </a>
          </li>
          <li class="c-global-navigation-list-item">
            <a href="#about" class="c-global-navigation-list-item-body">
              <span lang="en">About</span>
            </a>
          </li>
          <li class="c-global-navigation-list-item">
            <a href="#item" class="c-global-navigation-list-item-body">
              <span lang="en">Item</span>
            </a>
          </li>
          <li class="c-global-navigation-list-item">
            <a href="#reason" class="c-global-navigation-list-item-body">
              <span lang="en">Reason</span>
            </a>
          </li>
          <li class="c-global-navigation-list-item">
            <a href="#flow" class="c-global-navigation-list-item-body">
              <span lang="en">Flow</span>
            </a>
          </li>
          <li class="c-global-navigation-list-item">
            <a href="#faq" class="c-global-navigation-list-item-body">
              <span lang="en">FAQ</span>
            </a>
          </li>
          <li class="c-global-navigation-list-item">
            <a href="#case" class="c-global-navigation-list-item-body">
              <span lang="en">Case Study</span>
            </a>
          </li>
        </ul>
        <ButtonCTA textMain="公式LINEから相談する" textSub="専門スタッフが完全サポート" />
      </nav>

      {/* :::::::::::::::::::::::::::::::::::::::::::::::::: */}
      {/* Navigation Drawer                                   */}
      {/* :::::::::::::::::::::::::::::::::::::::::::::::::: */}
      <NavigationDrawer />
    </div>
  </div>
</div>

<script>
  const nav = document.querySelector('.c-global-navigation');
  if (nav) {
    const onScroll = () => {
      nav.classList.toggle('is-scrolled', window.scrollY >= 100);
    };
    window.addEventListener('scroll', onScroll, { passive: true });
    onScroll();
  }
</script>
