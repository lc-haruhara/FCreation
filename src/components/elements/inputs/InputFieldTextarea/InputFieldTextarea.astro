---
import './InputFieldTextarea.scss';

import { InputFieldError, InputFieldHelpText, InputFieldLabel } from '@/components/elements/index';

type Props = {
  name: string;
  label?: string;
  required?: boolean;
  placeholder?: string;
  maxLength?: number;
  rows?: number;
  helpText?: string;
  error?: string;
  value?: string;
};

const {
  name,
  label,
  required,
  placeholder,
  maxLength,
  rows = 6,
  helpText,
  error,
  value = '',
}: Props = Astro.props;

const textareaId = name;
const errorId = `error-${name}`;
const helpTextId = `help-${name}`;
const countId = `count-${name}`;
const hasError = Boolean(error);

const describedBy = [
  helpText ? helpTextId : null,
  maxLength ? countId : null,
  hasError ? errorId : null,
]
  .filter(Boolean)
  .join(' ');
---

<div class="c-input-field _type-textarea">
  {label ? <InputFieldLabel as="label" for={textareaId} text={label} required={required} /> : null}

  <div class="c-input-field-input">
    <textarea
      id={textareaId}
      name={name}
      class:list={['c-input-field-textarea', { 'is-error': hasError }]}
      rows={rows}
      maxlength={maxLength}
      required={required}
      aria-invalid={hasError ? 'true' : 'false'}
      aria-describedby={describedBy || undefined}
      data-input-required={required ? '' : undefined}
      placeholder=" ">{value}</textarea
    >

    {helpText ? <InputFieldHelpText id={helpTextId} text={helpText} /> : null}

    {
      maxLength ? (
        <p class="c-input-field-count">
          <span id={countId}>{value.length}</span> / {maxLength}
        </p>
      ) : null
    }
  </div>

  <InputFieldError id={errorId} error={error} />
</div>
